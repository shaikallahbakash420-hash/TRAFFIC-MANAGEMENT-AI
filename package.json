{
  "name": "indian-traffic-ai-system",
  "version": "1.0.0",
  "description": "AI-Powered Smart Traffic Management System prototype for Indian cities",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "setup": "npm install && npm install --prefix backend && npm install --prefix frontend",
    "seed": "node mock-data/seeder.js",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
